+uint64
+sys_trace(void)
+{
+  int mask;
+  
+  // Lấy tham số từ người dùng (bỏ lệnh if đi)
+  argint(0, &mask);
+  
+  // Lưu mask vào tiến trình hiện tại
+  myproc()->trace_mask = mask;
+  
+  return 0;
+}
+extern int get_procinfo(int pid, uint64 addr);
+
+uint64
+sys_procinfo(void)
+{
+  int pid;
+  uint64 info_addr; // Địa chỉ của con trỏ struct procinfo
+
+  // Lấy 2 tham số: pid và địa chỉ con trỏ info
+  argint(0, &pid);
+  argaddr(1, &info_addr);
+
+  return get_procinfo(pid, info_addr);
+}
