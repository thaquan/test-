+int
+get_procinfo(int pid, uint64 addr)
+{
+  struct proc *p;
+  struct procinfo info;
+  int found = 0;
+
+  // Duyệt qua toàn bộ danh sách tiến trình
+  for(p = proc; p < &proc[NPROC]; p++){
+    acquire(&p->lock);
+    if(p->pid == pid && p->state != UNUSED){
+      // Nếu tìm thấy, chép thông tin vào biến info
+      info.pid = p->pid;
+      info.ppid = p->parent ? p->parent->pid : 0;
+      info.state = p->state;
+      info.sz = p->sz;
+      safestrcpy(info.name, p->name, sizeof(info.name));
+      found = 1;
+      release(&p->lock);
+      break;
+    }
+    release(&p->lock);
+  }
+
+  // Dùng hàm copyout để "bắn" dữ liệu từ Kernel ra ngoài cho User
+  if(found){
+    if(copyout(myproc()->pagetable, addr, (char *)&info, sizeof(info)) < 0)
+      return -1;
+    return 0;
+  }
+  return -1;
+}
